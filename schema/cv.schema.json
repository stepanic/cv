{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/stepanic/cv/schema/cv.schema.json",
  "title": "CV data schema (single source of truth)",
  "$defs": {
    "bilingual": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "required": ["en", "hr"],
          "properties": {
            "en": { "type": "string", "minLength": 1 },
            "hr": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        }
      ]
    },
    "link": {
      "type": "object",
      "required": ["label", "url"],
      "properties": {
        "label": { "type": "string" },
        "url": { "type": "string", "pattern": "^https?://" }
      },
      "additionalProperties": false
    },
    "profile": {
      "type": "object",
      "required": ["name", "title", "location", "email", "website", "summary", "links"],
      "properties": {
        "name": { "type": "string" },
        "name_ascii": { "type": "string" },
        "title": { "$ref": "#/$defs/bilingual" },
        "location": { "$ref": "#/$defs/bilingual" },
        "email": { "type": "string", "pattern": "^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$" },
        "website": { "type": "string" },
        "company": { "type": "string" },
        "summary": { "$ref": "#/$defs/bilingual" },
        "links": { "type": "array", "items": { "$ref": "#/$defs/link" }, "minItems": 1 },
        "languages": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "level"],
            "properties": {
              "name": { "$ref": "#/$defs/bilingual" },
              "level": { "$ref": "#/$defs/bilingual" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "experience": {
      "type": "object",
      "required": ["experience"],
      "properties": {
        "experience": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "company", "role", "start", "summary", "bullets"],
            "properties": {
              "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
              "company": { "$ref": "#/$defs/bilingual" },
              "url": { "type": "string" },
              "role": { "$ref": "#/$defs/bilingual" },
              "start": { "type": "string", "pattern": "^[0-9]{4}(-[0-9]{2})?$" },
              "end": {
                "oneOf": [
                  { "type": "null" },
                  { "type": "string", "pattern": "^[0-9]{4}(-[0-9]{2})?$" }
                ]
              },
              "location": { "$ref": "#/$defs/bilingual" },
              "summary": { "$ref": "#/$defs/bilingual" },
              "bullets": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["text"],
                  "properties": {
                    "text": { "$ref": "#/$defs/bilingual" },
                    "tags": { "type": "array", "items": { "type": "string" } },
                    "priority": { "type": "integer", "minimum": 1, "maximum": 3 }
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "skills": {
      "type": "object",
      "required": ["skills"],
      "properties": {
        "skills": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["group", "items"],
            "properties": {
              "group": { "$ref": "#/$defs/bilingual" },
              "items": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["name"],
                  "properties": {
                    "name": { "type": "string" },
                    "years": { "type": "integer", "minimum": 1 },
                    "core": { "type": "boolean" }
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "education": {
      "type": "object",
      "required": ["education"],
      "properties": {
        "education": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["degree", "school", "start", "end"],
            "properties": {
              "degree": { "$ref": "#/$defs/bilingual" },
              "school": { "$ref": "#/$defs/bilingual" },
              "start": { "type": "string" },
              "end": { "type": "string" },
              "location": { "$ref": "#/$defs/bilingual" }
            },
            "additionalProperties": false
          }
        },
        "certifications": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "issuer", "date"],
            "properties": {
              "name": { "$ref": "#/$defs/bilingual" },
              "issuer": { "type": "string" },
              "date": { "type": "string" },
              "url": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "project": {
      "type": "object",
      "required": ["id", "name", "featured", "order", "period", "role", "tech", "summary", "tags"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "name": { "type": "string" },
        "featured": { "type": "boolean" },
        "order": { "type": "integer" },
        "period": {
          "type": "object",
          "required": ["start"],
          "properties": {
            "start": { "type": "string" },
            "end": { "oneOf": [{ "type": "null" }, { "type": "string" }] }
          },
          "additionalProperties": false
        },
        "role": { "$ref": "#/$defs/bilingual" },
        "links": { "type": "array", "items": { "$ref": "#/$defs/link" } },
        "tech": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "summary": { "$ref": "#/$defs/bilingual" },
        "highlights": {
          "type": "array",
          "items": { "$ref": "#/$defs/bilingual" }
        },
        "tags": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    }
  }
}
